# cc — Provider API Keys
#
# Copy this file to ~/.config/cc/providers.env and fill in your keys.
# Only uncomment the providers you have keys for.
#
# You can also set CC_ENV_FILE to point to any env file:
#   export CC_ENV_FILE=~/my-keys.env
#
# IMPORTANT: Never commit this file to version control.

# ─── Anthropic (default) ─────────────────────────────────────────────────────
# Set via your shell profile: export ANTHROPIC_API_KEY=sk-ant-...
# Or uncomment below:
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── MiniMax ──────────────────────────────────────────────────────────────────
# Get your key at: https://platform.minimaxi.com/
# MINIMAX_API_KEY=your-minimax-key-here

# ─── GLM (via z.ai) ──────────────────────────────────────────────────────────
# Get your key at: https://z.ai/
# Z_GLM_API_KEY=your-z-ai-key-here

# ─── OpenRouter ───────────────────────────────────────────────────────────────
# Get your key at: https://openrouter.ai/
# Supports 100+ models: qwen3.6, deepseek, kimi, claude, etc.
# OPENROUTER_API_KEY=sk-or-your-key-here

# ─── Qwen (Alibaba Cloud / DashScope) ────────────────────────────────────────
# Get your key at: https://dashscope.console.aliyun.com/
# Uses the Anthropic-compatible endpoint (Singapore region).
# Use QWEN_API_KEY (underscore) — it auto-loads. QWEN-API-KEY (dash) also works.
# QWEN_API_KEY=your-dashscope-key-here

# ─── Kimi (kimi-for-coding, direct) ──────────────────────────────────────────
# Get your key at: https://platform.moonshot.ai/
# Uses the Kimi Code endpoint: https://api.kimi.com/coding/
# IMPORTANT: ENABLE_TOOL_SEARCH=FALSE is set automatically — Kimi's API does
# not support Claude Code's preliminary tool_search call and will return 400.
# KIMI-API-KEY=sk-kimi-your-key-here

# ─── DeepSeek ────────────────────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=sk-your-key-here

# ─── Ollama (local models) ────────────────────────────────────────────────────
# Ollama runs locally; models are auto-detected from /api/tags.
# Claude Code needs an Anthropic-compatible proxy in front of Ollama.
#
# Quickstart:
#   pip install litellm
#   litellm --model ollama/<model-name> --port 8082
#
# OLLAMA_BASE_URL=http://localhost:11434   # where Ollama itself runs (model discovery)
# OLLAMA_PROXY_URL=http://localhost:8082   # where the Anthropic proxy listens

# ─── Custom Provider ─────────────────────────────────────────────────────────
# For any provider with an Anthropic-compatible API:
# CC_CUSTOM_BASE_URL=https://your-provider.example.com/anthropic
# CC_CUSTOM_API_KEY=your-api-key-here
# CC_CUSTOM_MODEL=your-model-name
